# SSH keypair, the EC2 instance, and a stable Elastic IP. The keypair is
# generated by Terraform so this stack is self-contained — no manual
# ssh-keygen step. Both .pem files are written to var.ssh_key_dir with
# 0600 permissions so OpenSSH will accept them.

resource "tls_private_key" "lumen" {
  algorithm = "ED25519"
}

resource "local_sensitive_file" "ssh_private_key" {
  filename        = "${var.ssh_key_dir}/${var.project}-prod.pem"
  content         = tls_private_key.lumen.private_key_openssh
  file_permission = "0600"
}

resource "local_file" "ssh_public_key" {
  filename        = "${var.ssh_key_dir}/${var.project}-prod.pub"
  content         = tls_private_key.lumen.public_key_openssh
  file_permission = "0644"
}

resource "aws_key_pair" "lumen" {
  key_name   = "${var.project}-prod"
  public_key = tls_private_key.lumen.public_key_openssh
}

resource "aws_instance" "lumen" {
  ami                         = data.aws_ami.ubuntu_2404_arm64.id
  instance_type               = var.instance_type
  subnet_id                   = data.aws_subnets.default.ids[0]
  vpc_security_group_ids      = [aws_security_group.lumen.id]
  key_name                    = aws_key_pair.lumen.key_name
  associate_public_ip_address = true

  # cloud-init runs this as root on first boot. We:
  #   1. Pre-create the lumen user with passwordless sudo (script needs this
  #      so subsequent SSH-as-lumen can `sudo` without a tty/password).
  #   2. Drop a relaxed fail2ban jail BEFORE the bootstrap installs fail2ban
  #      so deploy traffic (rsync, scp, iterative ssh) doesn't get banned.
  #   3. Run the full aws-bootstrap.sh non-interactively with the EIP-derived
  #      nip.io domain.
  # User-data output ends up in /var/log/cloud-init-output.log on the box.
  user_data = templatefile("${path.module}/user_data.sh.tftpl", {
    bootstrap_script = file("${path.module}/../../scripts/aws-bootstrap.sh")
    admin_email      = "ahmedhobeishy.tools@gmail.com"
  })

  # The user_data hash is in user_data_replace_on_change, so changing the
  # bootstrap or template will force an instance replacement.
  user_data_replace_on_change = true

  root_block_device {
    volume_type           = "gp3"
    volume_size           = var.root_volume_gb
    delete_on_termination = true
    encrypted             = true
  }

  # Force IMDSv2 (token-based) — IMDSv1 is the credential-exfiltration
  # vector behind the Capital One breach. New instances launched today
  # should never accept v1 unless an old SDK forces it.
  metadata_options {
    http_endpoint               = "enabled"
    http_tokens                 = "required"
    http_put_response_hop_limit = 2
  }

  tags = {
    Name = "${var.project}-prod"
  }

  # Recreate if the AMI changes — Terraform's default is to ignore AMI
  # drift, but we WANT new AMIs to roll: Canonical patches Ubuntu LTS
  # roughly monthly and we don't want to be running last year's image.
  lifecycle {
    ignore_changes = []
  }
}

resource "aws_eip" "lumen" {
  instance = aws_instance.lumen.id
  domain   = "vpc"

  tags = {
    Name = "${var.project}-prod-eip"
  }
}
