# Build context for the Fly image is the repo root (see the
# Dockerfile.fly header). Keep the layer thin by excluding
# everything that isn't `apps/backend/` source + lockfile.

# --- noise we never want in the image ---
.git
.github
.idea
.vscode
.cache
.venv
.env
.env.*
*.log
*.tmp
node_modules
__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache
htmlcov
coverage.xml
.coverage*

# --- repo paths the Fly image doesn't need ---
# Frontend is deployed separately on Vercel.
apps/frontend
# Legacy Django prototype — read-only archive.
legacy
# Local docker-compose stacks and infra for the self-hosted
# reference deploy. Fly doesn't read these.
docker-compose.yml
docker-compose.prod.yml
infra/caddy
infra/postgres
infra/prometheus
# Vercel and Supabase configs live alongside this one; the
# Fly image doesn't need them.
infra/vercel
infra/supabase
# Generated and dev-only artifacts.
apps/backend/htmlcov
apps/backend/.pytest_cache
apps/backend/.ruff_cache
apps/backend/.mypy_cache
apps/backend/celerybeat-schedule*
apps/backend/lumen_backend.egg-info
apps/backend/openapi.json
# Docs/screenshots — never shipped in the runtime image.
docs
*.md
LICENSE
CODE_OF_CONDUCT.md
CONTRIBUTING.md
SECURITY.md
CHANGELOG.md
README.md
