{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter ./apps/frontend... install --frozen-lockfile && pnpm --filter ./apps/frontend build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "apps/frontend/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD ./apps/frontend ./infra/vercel",
  "env": {
    "NEXT_PUBLIC_API_BASE_URL": "@lumen_api_base_url",
    "NEXT_PUBLIC_WS_BASE_URL": "@lumen_ws_base_url",
    "API_INTERNAL_BASE_URL": "@lumen_api_internal_base_url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "github": {
    "silent": true,
    "autoJobCancelation": true
  }
}
