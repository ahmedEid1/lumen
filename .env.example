# ============================================================
# Lumen — environment template
# Copy to `.env` and fill the values. Never commit `.env`.
# ============================================================

# --- App -----------------------------------------------------
ENV=development                          # development | staging | production
APP_NAME=Lumen
APP_DOMAIN=localhost
LOG_LEVEL=INFO
TZ=UTC

# --- API -----------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
# Public origin of the Next.js frontend — used to build links in
# transactional emails (password reset, email verification). In prod
# this is the user-facing host, NOT the api.* subdomain.
WEB_BASE_URL=http://localhost:3000
API_WORKERS=2                            # ignored in dev (reload mode)
# pydantic-settings v2 parses ``list[str]`` env vars as JSON before the
# @field_validator(mode="before") runs, so this must be a JSON array.
# `http://web:3000` is required by the Playwright `e2e` profile, whose
# browser loads the bundle from that origin (iter 103). In production
# every entry must be a real public origin — the H6 boot guard strips
# localhost / .test entries before they hit the CORS middleware.
CORS_ORIGINS=["http://localhost:3000","http://web:3000"]

# --- Auth ----------------------------------------------------
# Both secrets must be at least 32 chars in production — the H6 prod
# guard refuses to boot with shorter keys (HS256 / RFC 7518 §3.2 floor).
# Generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-value-please
JWT_SECRET=change-me-to-a-long-random-value-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900             # 15 min
REFRESH_TOKEN_TTL_SECONDS=1209600        # 14 days
PASSWORD_RESET_TTL_SECONDS=1800          # 30 min

# Optional: reject passwords that appear in HIBP's breach list.
# Sends only the first 5 chars of the password's SHA-1 (k-anonymity).
# Defaults to off so dev/CI runs don't hit the network.
HIBP_ENABLED=false
HIBP_API_BASE=https://api.pwnedpasswords.com
HIBP_TIMEOUT_SECONDS=2.0

# --- Frontend ------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# --- Database ------------------------------------------------
# In production the H6 prod guard refuses to boot if DATABASE_URL points
# at a loopback host (localhost / 127.0.0.1) — use a real managed
# Postgres (Supabase / RDS / Neon / Crunchy).
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=lumen
POSTGRES_USER=lumen
POSTGRES_PASSWORD=lumen
DATABASE_URL=postgresql+asyncpg://lumen:lumen@db:5432/lumen
DATABASE_URL_SYNC=postgresql+psycopg://lumen:lumen@db:5432/lumen
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Storage (MinIO / S3-compatible) -------------------------
S3_ENDPOINT_URL=http://s3:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lumen-assets
S3_ACCESS_KEY_ID=lumen
S3_SECRET_ACCESS_KEY=lumen-secret
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=900
MINIO_ROOT_USER=lumen
MINIO_ROOT_PASSWORD=lumen-secret

# --- Email ---------------------------------------------------
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Lumen <no-reply@lumen.test>
SMTP_TLS=false

# --- Observability ------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=lumen-api
PROMETHEUS_ENABLED=true

# --- Embeddings (Phase E0) ----------------------------------
# ``local`` runs sentence-transformers in-process (CPU-friendly, 384-dim).
# ``openai`` calls text-embedding-3-small with dimensions=384.
# ``noop`` returns deterministic zeros — tests only.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_LOCAL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_OPENAI=text-embedding-3-small

# --- LLM (Phase E1/E2 + H1 cost log) ------------------------
# Provider for app.services.llm. ``noop`` returns deterministic canned
# text (CI / dev). The H6 prod guard refuses to boot with LLM_PROVIDER=noop.
#
# Production path (operator default, see docs/deployment/oracle-vps.md Step 5):
#   LLM_PROVIDER=openai
#   OPENAI_API_BASE=https://api.groq.com/openai/v1
#   OPENAI_API_KEY=<groq-key>
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Paid Anthropic path (Claude Sonnet 4.6 / Opus):
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=<key>
#   LLM_MODEL=claude-sonnet-4-6  # or claude-opus-4-7
LLM_PROVIDER=noop
# LLM_MODEL=llama-3.3-70b-versatile   # Groq's free-tier flagship; uncomment
                                       # alongside the LLM_PROVIDER=openai path
# ANTHROPIC_API_KEY=                   # uncomment for the paid Anthropic path
# ANTHROPIC_API_BASE=                  # only needed for non-default endpoints
LLM_MAX_TOKENS=1024

# OpenAI / Groq / any OpenAI-compatible endpoint.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_BASE=https://api.groq.com/openai/v1   # Groq free-tier (operator default)

# --- Content ingest (Phase E3) ------------------------------
# Optional Notion integration token. YouTube + Google Docs paths work
# without credentials (transcripts API + public-link export).
NOTION_TOKEN=

# --- Open Badges 3.0 / W3C VC (Phase E5) --------------------
# Issuer URL is embedded in every credential; must dereference to a
# Profile document in production (today the Lumen root suffices).
BADGES_ISSUER_URL=http://localhost:8000
# Ed25519 private key in PEM form. When unset, app.core.badges_keys
# derives one from SECRET_KEY for dev convenience — the prod guard
# refuses that fallback in production.
BADGES_SIGNING_KEY=

# --- Rate limits --------------------------------------------
# Per-minute caps surfaced via slowapi. Tuned for the free-tier deploy;
# the H7 dashboard reads 429 counts from app.core.rate_limit_metrics.
RATE_LIMIT_ANON_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_USER_PER_MINUTE=240

# --- Misc ---------------------------------------------------
SEED_DEMO=true
