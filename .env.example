# ============================================================
# Lumen — environment template
# Copy to `.env` and fill the values. Never commit `.env`.
# ============================================================

# ---------------- App ----------------
ENV=development                          # development | staging | production
APP_NAME=Lumen
APP_DOMAIN=localhost
LOG_LEVEL=INFO
TZ=UTC

# ---------------- API ----------------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
# Public origin of the Next.js frontend — used to build links in
# transactional emails (password reset, email verification). In prod
# this is the user-facing host, NOT the api.* subdomain.
WEB_BASE_URL=http://localhost:3000
API_WORKERS=2                            # ignored in dev (reload mode)
SECRET_KEY=change-me-to-a-long-random-value-please
JWT_SECRET=change-me-to-a-long-random-value-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900             # 15 min
REFRESH_TOKEN_TTL_SECONDS=1209600        # 14 days
PASSWORD_RESET_TTL_SECONDS=1800          # 30 min
# pydantic-settings v2 parses ``list[str]`` env vars as JSON before the
# @field_validator(mode="before") runs, so this must be a JSON array.
# `http://web:3000` is required by the Playwright `e2e` profile, whose
# browser loads the bundle from that origin (iter 103).
CORS_ORIGINS=["http://localhost:3000","http://web:3000"]

# Optional: reject passwords that appear in HIBP's breach list.
# Sends only the first 5 chars of the password's SHA-1 (k-anonymity).
# Defaults to off so dev/CI runs don't hit the network.
HIBP_ENABLED=false

# ---------------- Frontend ----------------
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ---------------- Database ----------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=lumen
POSTGRES_USER=lumen
POSTGRES_PASSWORD=lumen
DATABASE_URL=postgresql+asyncpg://lumen:lumen@db:5432/lumen
DATABASE_URL_SYNC=postgresql+psycopg://lumen:lumen@db:5432/lumen

# ---------------- Redis ----------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------- Object storage (MinIO / S3) ----------------
S3_ENDPOINT_URL=http://s3:9000
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=lumen-assets
S3_ACCESS_KEY_ID=lumen
S3_SECRET_ACCESS_KEY=lumen-secret
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=900
MINIO_ROOT_USER=lumen
MINIO_ROOT_PASSWORD=lumen-secret

# ---------------- Email ----------------
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Lumen <no-reply@lumen.test>
SMTP_TLS=false

# ---------------- Observability ----------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=lumen-api
PROMETHEUS_ENABLED=true

# ---------------- Misc ----------------
SEED_DEMO=true
